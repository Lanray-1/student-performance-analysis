# Copy this file to .env and fill in real values. Never commit .env itself.

# MLflow tracking server (leave blank for local ./mlruns)
MLFLOW_TRACKING_URI=

# FastAPI service config
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

